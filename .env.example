# Ark / Volces API
ARK_API_KEY=your_api_key_here

# Image Provider: Seedream
SEEDREAM_MODEL=doubao-seedream-5-0-pro-260628
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
SEEDREAM_MAX_WORKERS=32

# Video Provider: Seedance
SEEDANCE_MODEL=doubao-seedance-1-0-pro-250528
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MAX_WORKERS=10

# TTS Provider: Edge TTS (free, no API key required)
TTS_PROVIDER=edge_tts
TTS_VOICE=zh-CN-YunjianNeural
TTS_SPEED=1.2
