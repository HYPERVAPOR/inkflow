# Ark / Volces API
ARK_API_KEY=your_api_key_here

# Image Provider: Seedream
SEEDREAM_MODEL=doubao-seedream-5-0-pro-260628
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
SEEDREAM_MAX_WORKERS=32

# Video Provider: Seedance
SEEDANCE_MODEL=doubao-seedance-1-0-pro-250528
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MAX_WORKERS=10

# TTS Provider: edge_tts or volcano
TTS_PROVIDER=edge_tts

# Edge TTS (free, no API key required)
TTS_VOICE=zh-CN-YunjianNeural
TTS_SPEED=1.2

# Volcano TTS (Doubao / Seed-TTS)
# Required when TTS_PROVIDER=volcano
# New BytePlus Speech Console: use VOLCANO_TTS_API_KEY only (default v3 endpoint)
# Legacy Speech Console: use VOLCANO_TTS_APP_ID + VOLCANO_TTS_ACCESS_TOKEN + VOLCANO_TTS_CLUSTER
# To use legacy v1 endpoint, set VOLCANO_TTS_BASE_URL=https://openspeech.bytedance.com/api/v1/tts
VOLCANO_TTS_API_KEY=your_api_key_here
# VOLCANO_TTS_APP_ID=your_app_id_here
# VOLCANO_TTS_ACCESS_TOKEN=your_access_token_here
VOLCANO_TTS_CLUSTER=volcano_tts
VOLCANO_TTS_BASE_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
VOLCANO_TTS_RESOURCE_ID=volc.service_type.10029
VOLCANO_TTS_VOICE=zh_male_aojiaobazong_moon_bigtts
